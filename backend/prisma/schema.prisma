// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions    Subscription[]
  payments         Payment[]
  routineTemplates RoutineTemplate[]
  dailySchedules   DailySchedule[]
  dailyTargets     DailyTarget[]
  productivityLogs ProductivityLog[]

  @@index([email])
}

model Plan {
  id           String       @id @default(uuid())
  name         String
  description  String?
  price        Decimal      @db.Decimal(10, 2)
  billingCycle BillingCycle
  features     String[]
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  trialStartDate     DateTime?          @default(now())
  trialEndDate       DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([userId])
  @@index([planId])
  @@index([status])
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  subscriptionId String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         PaymentStatus @default(PENDING)
  paymentDate    DateTime      @default(now())
  invoiceId      String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

model RoutineTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  userId      String
  color       String?
  icon        String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules DailySchedule[]

  @@index([userId])
}

model DailySchedule {
  id                String     @id @default(uuid())
  userId            String
  routineTemplateId String?
  title             String
  description       String?
  dayOfWeek         DayOfWeek? // Optional, if it's a recurring weekly schedule
  date              DateTime?  @db.Date // Optional, if it's a specific date schedule
  startTime         DateTime   @db.Time
  endTime           DateTime   @db.Time
  isCompleted       Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineTemplate RoutineTemplate? @relation(fields: [routineTemplateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([routineTemplateId])
  @@index([date])
}

model DailyTarget {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  targetDate  DateTime @db.Date
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetDate])
}

model ProductivityLog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  score     Int      @default(0) // 1-100 or 1-10 score
  notes     String?
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}
